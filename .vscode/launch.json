{
    "version": "0.2.0",
    "configurations": [
        

        {
            "name": "Debug inference-perf",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/.venv/bin/inference-perf",
            "args": [
                "--config_file",
                "config.yml"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "PYTHONPATH": "${workspaceFolder}",
                "OBJC_DISABLE_INITIALIZE_FORK_SAFETY": "YES"
            },
            "python": "${workspaceFolder}/.venv/bin/python"
        },
        {
            "name": "Debug Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "python": "${workspaceFolder}/.venv/bin/python"
        },
